---
// src/layouts/Layout.astro
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<title>{title} | Cumbre Serena</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,400;0,700;1,700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body>
		
		<header class="site-header">
			<div class="mobile-header">
					<a href="/" class="logo-link">
						<img src="/img/logo_canbuyon.png" alt="Logo Cumbre Serena" class="header-logo-img" />
						<div class="logo-text-group">
							<span class="brand-title"><strong>CANBUYON</strong><span class="logo-accent">FILMS</span></span>
						</div>
					</a>
					<div class="mobile-actions">
						<button aria-label="Menú" id="hamburgerBtn">
							<svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
						</button>
					</div>
				</div>
				<div class="mobile-menu-overlay" id="mobileMenuOverlay">
			<button class="close-menu-btn" id="closeMenuBtn" aria-label="Cerrar menú">
				<svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
			</button>
			<nav class="mobile-menu-nav">
				<ul>
					<li><a href="/">INICIO</a></li>
					<li><a href="/about">QUIÉNES SOMOS</a></li>
					<li><a href="/#proyectos">PROYECTOS</a></li>
					<li><a href="/marcas">NUESTRAS MARCAS</a></li>
					<li><a href="/contact">CONTACTO</a></li>
				</ul>
			</nav>
		</div>

				<div class="desktop-header">
					<div class="logo-wrapper">
						<a href="/" class="logo-link-large">
							<img src="/img/logo_canbuyon.png" alt="Logo Cumbre Serena" class="header-logo-img" />
							<div class="logo-text-group">
								<span class="brand-title"><strong>CANBUYON</strong><span class="logo-accent">FILMS</span></span>
								
							</div>
						</a>
					</div>
					
					<div class="nav-wrapper">
						<nav class="main-nav">
							<ul>
								<li><a href="/">INICIO</a></li>
								<li><a href="/about">QUIÉNES SOMOS</a></li>
								<li><a href="/#proyectos">PROYECTOS</a></li>
								<li><a href="/marcas">NUESTRAS MARCAS</a></li>
								<li><a href="/contact">CONTACTO</a></li>
							</ul>
						</nav>
					</div>
				</div>

			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-content">
				
				<img src="/img/logo_canbuyon.png" alt="Logo Cumbre Serena" class="footer-logo-img">
				<div class="footer-logo-text">CANBUYON FILMS</div>
				
				<div class="footer-social">
					<a href="#" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
						<svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
					</a>
					<a href="#" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
						<svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
					</a>
					<a href="#" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
						<svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
					</a>
					<a href="#" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
						<svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
					</a>
				</div>
				
				<div class="footer-legal">
					<a href="/privacidad">Política de Privacidad</a>
					<span class="separator">·</span>
					<a href="/aviso-legal">Aviso Legal</a>
				</div>

			</div>
			
			<div class="footer-bottom">
				<p>© 2026 Canbuyon Flims. Todos los derechos reservados.</p>
			</div>
		</footer>

	</body>
</html>

<script>
	const hamburgerBtn = document.getElementById('hamburgerBtn');
	const closeMenuBtn = document.getElementById('closeMenuBtn');
	const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');
	const mobileLinks = document.querySelectorAll('.mobile-menu-nav a');

	// Al hacer clic en las 3 rayitas, abrimos el menú
	if (hamburgerBtn && mobileMenuOverlay) {
		hamburgerBtn.addEventListener('click', () => {
			mobileMenuOverlay.classList.add('active');
			document.body.style.overflow = 'hidden'; // Bloquea el scroll de fondo
		});
	}

	// Al hacer clic en la "X", cerramos el menú
	if (closeMenuBtn && mobileMenuOverlay) {
		closeMenuBtn.addEventListener('click', () => {
			mobileMenuOverlay.classList.remove('active');
			document.body.style.overflow = ''; // Devuelve el scroll
		});
	}

	// Crucial: Si hacen clic en una sección (como #proyectos), cerramos el menú automáticamente
	mobileLinks.forEach(link => {
		link.addEventListener('click', () => {
			if (mobileMenuOverlay) {
				mobileMenuOverlay.classList.remove('active');
				document.body.style.overflow = '';
			}
		});
	});
</script>

<style is:global lang="scss">
	/* ==========================================
	   1. VARIABLES DE DISEÑO (SASS + NATIVAS)
	   ========================================== */
	$color-bg:        #0a0a0a;
	$color-text:      #F5F5F5;
	$color-accent:    #e74136; 
	$font-body:       'Playfair Display', 'Montserrat', 'Cinzel', serif;
	$font-title:      'Barlow', 'Poppins', 'Inter', sans-serif;
	$max-width-site:  1200px; /* Medida global para contener toda la web */

	:root {
		--test-bg-page: #000000; /* Fondo general de la página */
		--site-bg: #{$color-bg};
		--site-text: #{$color-text};
		--site-accent: #{$color-accent};
		--font-body: #{$font-body};
		--font-title: #{$font-title};
	}

	/* ==========================================
	   2. RESETS GLOBALES Y TIPOGRAFÍA BASE
	   ========================================== */
	*, *::before, *::after { 
		box-sizing: border-box; 
		margin: 0; 
		padding: 0; 
	}
	
	html { 
		scroll-behavior: auto !important; 
	}
	
	body { 
		font-family: var(--font-body);
		color: #333;
		background-color: var(--test-bg-page); 
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}
	
	h1, h2, h3, h4, .logo-link, .logo-link-large, nav a, button {
		font-family: var(--font-title);
	}
	
	a { text-decoration: none; color: inherit; }
	ul { list-style: none; }
	button { background: none; border: none; cursor: pointer; color:inherit }

	/* ==========================================
	   3. HEADER GENERAL & STICKY
	   ========================================== */
	.site-header {
		background-color: var(--test-bg-page); 
		border-bottom: 1px solid rgba(0,0,0,0.05);
		position: sticky;
		top: 0;
		z-index: 999;
	}
	
	.header-container { 
		width: 100%;
		max-width: $max-width-site;
		margin: 0 auto; 
		padding: 0 1rem; 
	}

	/* ==========================================
	   4. MARCA Y LOGO (COMÚN MOBILE/DESKTOP)
	   ========================================== */
	.logo-link, .logo-link-large {
		display: flex;
		align-items: center;
	}
	
	.header-logo-img {
		height: auto;
		opacity: 0.95;
	}

	.logo-text-group {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		line-height: 1;
	}

	.brand-title {
		font-family: var(--font-title);
		color: #333;
		display: flex;       
		align-items: baseline; /* Alineación perfecta por la base de las letras */
		
		strong { 
			color: #ffffff; 
			font-weight: 700; 
			margin-left: 0.2rem; 
		}
	}

	.logo-accent {
		display: block;
		font-family: sans-serif;
		font-style: normal; 
		font-weight: 700;
		color: var(--site-accent);
		text-align: left;
	}

	/* ==========================================
	   5. HEADER VERSIÓN MÓVIL (MOBILE FIRST)
	   ========================================== */
	.mobile-header {
		display: flex; 
		justify-content: space-between; 
		align-items: center; 
		height: 60px;
		
		.logo-link { gap: 0.6rem; }
		.header-logo-img { width: 52px; }
		.brand-title { font-size: 1.1rem; }
		.logo-accent { 
			font-size: 0.55rem; 
			letter-spacing: 2px; 
			margin-top: 3px; 
		}
	}

	.mobile-actions { 
		display: flex; 
		gap: 1rem; 
		color: var(--site-text); 
	}
	#hamburgerBtn {
		color: #ffffff;
		background: transparent;
		border: none;
		padding: 0.5rem; /* Amplía la zona táctil para que sea más fácil darle en el móvil */
		margin-right: 0.5rem; /* Lo alinea perfectamente con el borde derecho */
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: color 0.2s ease, transform 0.2s ease;

		&:hover, &:active {
			color: var(--site-accent);
			transform: scale(1.05);
		}
	}

	/* ==========================================
	   ESTILOS DEL MENÚ DESPLEGABLE MÓVIL
	   ========================================== */
	.mobile-menu-overlay {
		position: fixed;
		inset: 0;
		background-color: rgba(10, 10, 10, 0.98); /* Fondo casi negro opaco */
		z-index: 10000; /* Asegura que se abra por encima de todo */
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.4s ease, visibility 0.4s ease;

		/* Clase que añadiremos con JS para mostrarlo */
		&.active {
			opacity: 1;
			visibility: visible;
		}
	}

	.close-menu-btn {
		position: absolute;
		top: 15px;
		right: 15px;
		color: #ffffff;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
		
		&:hover {
			color: var(--site-accent);
		}
	}

	.mobile-menu-nav {
		ul {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 2.5rem; /* Separación generosa entre enlaces */
		}

		a {
			font-family: var(--font-title);
			font-size: 1.8rem;
			font-weight: 700;
			color: #ffffff;
			letter-spacing: 2px;
			transition: color 0.2s ease;

			&:hover {
				color: var(--site-accent);
			}
		}
	}

	.desktop-header { display: none; } 

	/* ==========================================
	   6. HEADER VERSIÓN DESKTOP (PC)
	   ========================================== */
	@media (min-width: 1024px) {
		.mobile-header { display: none; }
		
		.desktop-header { 
			display: flex; 
			flex-direction: column; 
			align-items: center; 
			padding: 2.5rem 0 1.5rem; 
		}
		
		.logo-wrapper { margin-bottom: 2rem; }
		.logo-link-large { gap: 0.8rem; }
		
		.desktop-header {
			.header-logo-img { width: 4.5rem; }
			.brand-title { font-size: 2.2rem; letter-spacing: 1px; }
			.logo-accent { font-size: 2rem; letter-spacing: 4px; margin-top: 6px; }
		}

		/* MENÚ DE NAVEGACIÓN PC */
		.nav-wrapper { 
			display: flex; 
			width: 100%; 
			justify-content: center; 
			align-items: center; 
		}
		
		.main-nav ul { 
			display: flex; 
			align-items: center; 
			gap: 0.5rem; 
		}
		
		.main-nav li {
			position: relative; 
			padding: 0 1.5rem;
			
			&:not(:last-child)::after {
				content: ''; 
				position: absolute; 
				right: 0; 
				top: 50%;
				transform: translateY(-50%);
				height: 12px; 
				width: 1px; 
				background-color: rgba(0,0,0,0.15); /* Divisor sutil */
			}
		}
		
		.main-nav a {
			font-size: 0.9rem; 
			font-weight: 700; 
			color: #666; 
			transition: color 0.2s;
			text-transform: uppercase; 
			letter-spacing: 1px;
			
			&:hover, &.active { color: var(--site-accent); }
		}
	}

	/* ==========================================
	   7. FOOTER PRINCIPAL
	   ========================================== */
	.site-footer {
		background-color: var(--site-bg);
		padding: 4rem 1.5rem 2rem 1.5rem;
		text-align: center;
	}
	
	.footer-content {
		display: flex; 
		flex-direction: column; 
		align-items: center; 
		width: 100%;
		max-width: $max-width-site; 
		margin: 0 auto;
	}
	
	.footer-logo-img { 
		width: 8rem; 
		margin-bottom: 1rem; 
		opacity: 0.9; 
	}
	
	.footer-logo-text {
		font-family: var(--font-title); 
		font-size: 1.2rem; 
		letter-spacing: 4px;
		color: rgba(255, 255, 255, 0.8); 
		margin-bottom: 2rem; 
		text-transform: uppercase;
	}
	
	.footer-social {
		display: flex; 
		justify-content: center; 
		gap: 2rem; 
		margin-bottom: 2rem;
		
		a {
			color: var(--site-accent); 
			transition: color 0.3s ease, transform 0.2s ease;
			
			&:hover { 
				color: #ffffff; 
				transform: translateY(-3px); 
			}
		}
	}
	
	.footer-legal {
		margin-bottom: 3rem;
		
		a, .separator {
			color: rgba(255, 255, 255, 0.4); 
			text-decoration: none; 
			font-size: 0.8rem;
			font-family: var(--font-title); 
			margin: 0 0.5rem; 
			transition: color 0.2s;
		}
		
		a:hover { color: var(--site-accent); }
	}
	
	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.05); 
		padding-top: 2rem; 
		width: 100%;
		max-width: $max-width-site; 
		margin: 0 auto;
		
		p {
			color: rgba(255, 255, 255, 0.3); 
			font-size: 0.75rem; 
			font-family: var(--font-title); 
			margin: 0;
		}
	}

	
</style>

