---
import Layout from '../layouts/Layout.astro';

// Aquí tienes la lista del equipo. Cuando tengas las fotos reales, 
// solo tienes que subir la foto a la carpeta public/img/ y cambiar el nombre aquí.
// SECCIÓN EQUIPO: Añade o quita elementos aquí dentro. Se generarán solos en la web.
const equipo = [
	{ 
		nombre: "Edurado Álvarez", 
		cargo: "Productor ejecutivo | Director de cinematografía", 
		bio: "Con una sólida trayectoria en dirección de fotografía, aporta una visión artística única y técnica avanzada para capturar imágenes que potencian cada historia que contamos.", 
		src: "/img/eduardo.webp" 
	},
	{ 
		nombre: "Ana Morales", 
		cargo: "Directora de producción", 
		bio: "Con una trayectoria extensa, aporta visión y liderazgo en cada rodaje.", 
		src: "/img/ana.webp" 
	},
	{ 
		nombre: "Carlos Díaz", 
		cargo: "Director de fotografía", 
		bio: "Destaca por su ojo artístico y su talento para capturar imágenes únicas.", 
		src: "/img/carlos.webp" 
	},
	{ 
		nombre: "Lucia Fernández", 
		cargo: "Editora Senior", 
		bio: "Especializada en postproducción, garantiza resultados visuales impactantes.", 
		src: "/img/lucia.webp" 
	},
];

// 1. AÑADE AQUÍ TUS FOTOS DE RODAJES
// Solo tienes que subir la foto a public/img/rodajes/ y añadir el nombre aquí.
const fotosRodaje = [
	{ src: "/img/rodaje1.webp", alt: "Rodaje  - Canbuyon Films" },
	{ src: "/img/rodaje2.webp", alt: "Cámaras y equipo técnico" },
	{ src: "/img/rodaje3.webp", alt: "Dirección de actores" },
	{ src: "/img/rodaje4.webp", alt: "Preparación actrices" },
	{ src: "/img/rodaje5.webp", alt: "Rodaje exterior" },
	{ src: "/img/rodaje6.webp", alt: "Set iluminación" },
	{ src: "/img/rodaje7.webp", alt: "Rodaje interior" },
	{ src: "/img/rodaje8.webp", alt: "Exterior 1" },
	{ src: "/img/rodaje9.webp", alt: "Equipo técnico" },
	{ src: "/img/rodaje10.webp", alt: "Rodaje dubrovka" },
	{ src: "/img/rodaje11.webp", alt: "Rodaje dubrovka" },
	{ src: "/img/rodaje12.webp", alt: "Rodaje cámara" },
	{ src: "/img/rodaje13.webp", alt: "Claqueta, acción" },
    // Puedes seguir añadiendo hasta 10, 15 o las que quieras...
];
---

<Layout title="Quiénes Somos" description="Conoce al equipo detrás de Cumbre Serena World Productions.">
	
	<main class="about-page">
		
		<section class="about-hero">
			<div class="hero-container">
				<span class="section-badge">LA PRODUCTORA</span>
				<h1 class="hero-title">Excelencia en producción audiovisual profesional</h1>
				
				<div class="hero-description">
					<p>Nuestro compromiso es crear proyectos audiovisuales que fusionan creatividad e innovación, impulsados por la pasión de contar historias que conectan y perduran.</p>
					<p>Creamos películas que combinan arte y técnica para emocionar y sorprender.</p>
					<p>En canbuyonfilms.com nuestra meta es transformar ideas en historias visuales poderosas, guiados por la pasión por la creatividad y el compromiso con la excelencia.</p>
				</div>
			</div>
		</section>

		<section class="editorial-team">
			<h2 class="section-title">EQUIPO</h2>
			{equipo.map((miembro, index) => (
				<article class={`member-block ${index % 2 !== 0 ? 'reverse' : ''}`}>
					<div class="member-text">
						<div class="text-content">
							<span class="member-role">{miembro.cargo}</span>
							<h2 class="member-name">{miembro.nombre}</h2>
							<p class="member-bio">{miembro.bio}</p>
						</div>
					</div>
					<div class="member-image">
						<img src={miembro.src} alt={miembro.nombre ? `Retrato de ${miembro.nombre}` : "Retrato del equipo"} loading="lazy" />
					</div>
				</article>
			))}
		</section>

		<section class="stats-section">
			<div class="stats-container">
				<div class="stats-header">
					<h2>Fusionamos creatividad y técnica para narrar cada proyecto con autenticidad</h2>
					<p>Aquí presentamos datos clave que reflejan nuestro impacto y el éxito de nuestras producciones</p>
				</div>
				
				<div class="stats-grid">
					<article class="stat-card">
						<span class="stat-number">130</span>
						<h3 class="stat-title">Proyectos Finalizados</h3>
						<p class="stat-desc">Número total de producciones audiovisuales exitosas realizadas con dedicación y calidad</p>
					</article>
					
					<article class="stat-card">
						<span class="stat-number">210</span>
						<h3 class="stat-title">Clientes Satisfechos</h3>
						<p class="stat-desc">Cantidad de clientes que han confiado en nosotros para llevar sus historias al cine</p>
					</article>
					
					<article class="stat-card">
						<span class="stat-number">320</span>
						<h3 class="stat-title">Premios Obtenidos</h3>
						<p class="stat-desc">Reconocimientos recibidos en festivales y certámenes del ámbito audiovisual</p>
					</article>
				</div>
			</div>
		</section>

		<section class="bts-section">
			<div class="bts-header">
				<div class="header-content">
					<h2 class="bts-title">BEHIND THE SCENES</h2>
					<p class="bts-subtitle">Con las manos en la masa...</p>
				</div>
				<div class="bts-controls">
					<button class="bts-arrow prev" id="btsPrev" aria-label="Anterior">
						<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
					</button>
					<button class="bts-arrow next" id="btsNext" aria-label="Siguiente">
						<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
					</button>
				</div>
			</div>

			<div class="bts-track-container">
				<div class="bts-track" id="btsTrack">
					<div class="bts-slide-set">
						{fotosRodaje.map((foto) => (
							<div class="bts-item">
								<img src={foto.src} alt={foto.alt} loading="lazy" />
							</div>
						))}
					</div>
					<div class="bts-slide-set">
						{fotosRodaje.map((foto) => (
							<div class="bts-item">
								<img src={foto.src} alt={foto.alt} loading="lazy" />
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

	</main>

</Layout>

<script>
	const track = document.getElementById('btsTrack');
	const prevBtn = document.getElementById('btsPrev');
	const nextBtn = document.getElementById('btsNext');

	if (track && prevBtn && nextBtn) {
		let baseSpeed = 2; 
		let currentSpeed = baseSpeed; 
		let targetSpeed = baseSpeed; 
		let isHovered = false;
		let isFastForwarding = false; // Chivato para saber si estamos apretando el botón

		// 1. MOTOR DE GIRO CON INERCIA
		function loopCarrusel() {
			if (!track) return;

			// Suaviza la transición de velocidad (acelera y frena con estilo)
			currentSpeed += (targetSpeed - currentSpeed) * 0.1;
			track.scrollLeft += currentSpeed;
			
			const mitadWidth = track.scrollWidth / 2;
			
			if (track.scrollLeft >= mitadWidth) {
				track.scrollLeft -= mitadWidth; 
			} else if (track.scrollLeft <= 0) {
				track.scrollLeft += mitadWidth;
			}
			
			requestAnimationFrame(loopCarrusel);
		}

		requestAnimationFrame(loopCarrusel);

		// 2. PAUSA AL PASAR EL RATÓN (Solo si no estamos usando las flechas)
		function setHover(state: boolean) {
			isHovered = state;
			if (!isFastForwarding) { 
				targetSpeed = state ? 0 : baseSpeed;
			}
		}

		track.addEventListener('mouseenter', () => setHover(true));
		track.addEventListener('mouseleave', () => setHover(false));
		track.addEventListener('touchstart', () => setHover(true), { passive: true });
		track.addEventListener('touchend', () => setHover(false));
		track.addEventListener('touchcancel', () => setHover(false)); 

		// 3. LA MECÁNICA DE MANTENER PULSADO
		function startAcceleration(speed: number) {
			isFastForwarding = true;
			targetSpeed = speed; // Pisamos el acelerador a la velocidad que le pasemos (ej: 18 o -18)
		}

		function stopAcceleration() {
			isFastForwarding = false;
			// Al soltar el botón, comprobamos: si el ratón está sobre las fotos, se para (0). Si no, vuelve a velocidad de paseo.
			targetSpeed = isHovered ? 0 : baseSpeed;
		}

		// EVENTOS PARA EL BOTÓN "SIGUIENTE" (Avanzar)
		// Ordenadores
		nextBtn.addEventListener('mousedown', () => startAcceleration(8));
		nextBtn.addEventListener('mouseup', stopAcceleration);
		nextBtn.addEventListener('mouseleave', stopAcceleration); // Por si arrastran el ratón fuera del botón
		
		// Móviles
		nextBtn.addEventListener('touchstart', (e: Event) => { e.preventDefault(); startAcceleration(8); }, { passive: false });
		nextBtn.addEventListener('touchend', stopAcceleration);
		nextBtn.addEventListener('touchcancel', stopAcceleration);
		nextBtn.addEventListener('contextmenu', (e: Event) => e.preventDefault()); // Evita que salga el menú de opciones en iOS al mantener pulsado

		// EVENTOS PARA EL BOTÓN "ANTERIOR" (Rebobinar)
		// Ordenadores
		prevBtn.addEventListener('mousedown', () => startAcceleration(-18));
		prevBtn.addEventListener('mouseup', stopAcceleration);
		prevBtn.addEventListener('mouseleave', stopAcceleration);
		
		// Móviles
		prevBtn.addEventListener('touchstart', (e: Event) => { e.preventDefault(); startAcceleration(-18); }, { passive: false });
		prevBtn.addEventListener('touchend', stopAcceleration);
		prevBtn.addEventListener('touchcancel', stopAcceleration);
		prevBtn.addEventListener('contextmenu', (e: Event) => e.preventDefault());
	}
</script>

<style lang="scss">
	/* ==========================================
	   HERO (TEXTOS EN NEGRO - ESTILO INDEX)
	   ========================================== */
	.about-hero {
		background-color: var(--site-bg); /* Fondo negro */
		padding: 6rem 1.5rem 5rem;
		text-align: center;
	}

	.hero-container {
		max-width: 800px;
		margin: 0 auto;
	}

	.section-badge {
		font-family: var(--font-title);
		color: var(--site-accent);
		letter-spacing: 4px;
		font-size: 0.9rem;
		text-transform: uppercase;
		display: block;
		margin-bottom: 1.5rem;
	}

	.hero-title {
		font-family: var(--font-title); 
		font-size: 2rem;
		color: #ffffff;
		line-height: 1.2;
		margin-bottom: 2.5rem;
		
		@media (min-width: 768px) {
			font-size: 2.8rem;
		}
	}

	.hero-description {
		p {
			font-family: var(--font-title);
			font-size: 1.1rem;
			color: rgba(255, 255, 255, 0.7);
			line-height: 1.8;
			margin-bottom: 1.5rem;
			text-align: left;
			
			@media (min-width: 768px) {
				text-align: center;
			}
		}
	}

	/* ==========================================
	   ESTILO EDITORIAL PARA EL EQUIPO
	   ========================================== */
	.editorial-team {
		background-color: #000000;
		width: 100%;
		padding: 4rem 1.5rem; /* Añade espacio arriba y abajo del bloque entero */
	}

	.member-block {
		display: flex;
		flex-direction: column;
		max-width: 1100px; /* Limita el ancho para que no pegue a los bordes */
		margin: 0 auto 4rem auto; /* Lo centra y separa cada bloque del siguiente */
		background-color: #0a0a0a; /* Le damos fondo a la tarjeta completa */
		border-radius: 8px; /* Un toque suavizado opcional */
		overflow: hidden; /* Asegura que la foto no se salga de las esquinas redondeadas */

		@media (min-width: 768px) {
			flex-direction: row;
			min-height: 400px; /* Reduce la altura mínima para un look más compacto */
			
			&.reverse { 
				flex-direction: row-reverse; 
			}
		}
	}

	.member-text {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 3rem 2rem;
		background-color: transparent; /* El fondo ya lo tiene el contenedor padre */

		@media (min-width: 768px) {
			padding: 4rem;
		}

		.text-content {
			width: 100%;
			max-width: 450px;
		}
	}

	.member-role {
		color: var(--site-accent);
		font-family: var(--font-title);
		font-size: 0.8rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		display: block;
		margin-bottom: 0.8rem;
	}

	.member-name {
		font-family: var(--font-title);
		font-size: 2.2rem;
		color: #ffffff;
		margin-bottom: 1.2rem;
		line-height: 1.1;
		text-transform: uppercase;
	}

	.member-bio {
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.6;
		font-size: 1rem;
	}

	.member-image {
		width: 100%;
		height: 50dvh; /* ¡Ahora sí! Pon aquí la altura que te dé la gana para el móvil */
		
		@media (min-width: 768px) { 
			flex: 1; /* Le devolvemos el comportamiento flex solo en PC */
			height: 60dvh; /* En PC se estirará para igualar al bloque de texto */
		}

		img {
			width: 100%;
			height: 100%;
			object-fit: cover; 
			object-position: center; 
			display: block;
		}
	}

	/* ==========================================
	   SECCIÓN ESTADÍSTICAS (DATOS CLAVE)
	   ========================================== */
	.stats-section {
		background-color: var(--site-bg);
		padding: 6rem 1.5rem;
		width: 100%;
	}

	.stats-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	.stats-header {
		width: 100%;
		max-width: 800px;
		margin: 0 auto 4rem auto;
		display: flex;
		flex-direction: column;
		align-items: center; /* Centra las cajas de texto (h2 y p) en el eje transversal */
		text-align: center;

		h2 {
			font-family: var(--font-title);
			font-size: clamp(2rem, 4vw, 3.5rem);
			color: #ffffff;
			line-height: 1.1;
			margin-bottom: 1.5rem;
			
		}

		p {
			font-family: var(--font-body); /* Usamos la tipografía serif para darle el toque clásico de la captura */
			font-size: 1.2rem;
			color: rgba(255, 255, 255, 0.7);
			line-height: 1.6;
			
		}
	}

	.stats-grid {
		display: grid;
		grid-template-columns: 1fr; /* En móvil, 1 columna */
		gap: 1.5rem;

		@media (min-width: 768px) {
			grid-template-columns: repeat(3, 1fr); /* En tablet/PC, 3 columnas iguales */
			gap: 2rem;
		}
	}

	.stat-card {
		background-color: #0a0a0a; /* Un negro ligeramente más claro para que resalte sobre el fondo */
		padding: 3rem 2.5rem;
		border-radius: 4px;
		border: 1px solid rgba(255, 255, 255, 0.05); /* Borde sutil para enmarcar */
		transition: transform 0.3s ease, border-color 0.3s ease;

		&:hover {
			transform: translateY(-5px); /* Efecto de levitación al pasar el ratón */
			border-color: rgba(255, 255, 255, 0.15);
		}
	}

	.stat-number {
		display: block;
		font-family: var(--font-title);
		font-size: 3.5rem;
		font-weight: 700;
		color: #ffffff;
		line-height: 1;
		margin-bottom: 1rem;
	}

	.stat-title {
		font-family: var(--font-title);
		font-size: 1.2rem;
		color: #ffffff;
		margin-bottom: 1rem;
	}

	.stat-desc {
		font-family: var(--font-body);
		font-size: 0.95rem;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.6;
	}

	/* ==========================================
	   SECCIÓN RODAJES (FONDO OSCURO)
	   ========================================== */
	.bts-section {
		background-color: #0a0a0a;
		padding: 5rem 0; /* Sin padding lateral para que el track llegue al borde */
		overflow: hidden;
	}

	.bts-header {
		max-width: 1200px;
		margin: 0 auto 3rem;
		padding: 0 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
	}

	.bts-title {
		font-family: var(--font-title);
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: 4px;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}

	.bts-subtitle {
		font-family: var(--font-title);
		font-size: 0.9rem;
		color: var(--site-accent);
		text-transform: uppercase;
		margin: 0;
	}

	.bts-controls {
		display: flex;
		gap: 1rem;
		
		.bts-arrow {
			width: 45px;
			height: 45px;
			border: 1px solid rgba(255,255,255,0.2);
			border-radius: 50%;
			color: white;
			display: flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			background: transparent;
			transition: all 0.3s ease;
			
			&:hover {
				background-color: var(--site-accent);
				border-color: var(--site-accent);
				transform: scale(1.05);
			}
			&:active {
				transform: scale(0.95);
			}
		}
	}

	.bts-track-container {
		padding: 0;
		overflow: hidden;
		width: 100%;
	}

	.bts-track {
		display: flex;
		width: 100%;
		overflow-x: auto; /* Fundamental para que iOS permita el movimiento */
		scroll-behavior: auto; 
		scrollbar-width: none; /* Oculta barra en Firefox */
		&::-webkit-scrollbar { display: none; } /* Oculta barra en Safari/iPhone */
	}

	.bts-slide-set {
		display: flex;
		gap: 1.5rem;
		padding-right: 1.5rem; /* Separación con el clon */
	}

	.bts-item {
		width: 280px; /* Medida fija para que el script calcule bien el infinito */
		flex-shrink: 0;
		aspect-ratio: 16 / 9;
		border-radius: 4px;
		overflow: hidden;
		background-color: #1a1a1a;

		@media (min-width: 768px) { width: 350px; }
		@media (min-width: 1024px) { width: 420px; }

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			transition: transform 0.5s ease;
			
			&:hover {
				transform: scale(1.3);
			}
		}
	}
	.section-title { font-family: var(--font-title); 
		font-size: 1.5rem; 
		font-weight: 700; 
		color: #ffffff; 
		margin: 2rem; }

	
</style>