---
import Layout from '../layouts/Layout.astro';

// Aquí tienes la lista del equipo. Cuando tengas las fotos reales, 
// solo tienes que subir la foto a la carpeta public/img/ y cambiar el nombre aquí.
const equipo = [
	{ nombre: "EDUARDO ALVAREZ", cargo: "PRODUCTOR EJECUTIVO", imagen: "/img/eduardopic.webp" },
	{ nombre: "X", cargo: "PRODUCTOR EJECUTIVO", imagen: "/img/" },
	{ nombre: "X", cargo: "PRODUCTOR EJECUTIVO", imagen: "/img/" },
	{ nombre: "X", cargo: "GUIONISTA", imagen: "/img/" },

];

// 1. AÑADE AQUÍ TUS FOTOS DE RODAJES
// Solo tienes que subir la foto a public/img/rodajes/ y añadir el nombre aquí.
const fotosRodaje = [
	{ src: "/img/rodaje1.webp", alt: "Rodaje  - Canbuyon Films" },
	{ src: "/img/rodaje2.webp", alt: "Cámaras y equipo técnico" },
	{ src: "/img/rodaje3.webp", alt: "Dirección de actores" },
	{ src: "/img/rodaje4.webp", alt: "Preparación actrices" },
    // Puedes seguir añadiendo hasta 10, 15 o las que quieras...
];
---

<Layout title="Quiénes Somos" description="Conoce al equipo detrás de Cumbre Serena World Productions.">
	
	<main class="about-page">
		
		<section class="about-hero">
			<div class="hero-container">
				<span class="section-badge">LA PRODUCTORA</span>
				<h1 class="hero-title">Cine con identidad, rigor y proyección.</h1>
				
				<div class="hero-description">
					<p>Cumbre Serena nace de la unión de profesionales apasionados por la narrativa cinematográfica. Nuestra filosofía se basa en crear historias con una mirada creativa clara, respaldada por una gestión técnica y financiera precisa.</p>
					<p>Trabajamos con talento emergente y consolidado para desarrollar proyectos que no solo emocionen, sino que tengan una base sólida para viajar internacionalmente.</p>
				</div>
			</div>
		</section>

		<section class="team-section">
			<div class="team-container">
				<h2 class="team-title">EL EQUIPO</h2>
				
				<div class="team-grid">
					{equipo.map((miembro) => (
						<article class="team-card">
							<div class="img-wrapper">
								<img src={miembro.imagen} alt={`Foto de ${miembro.nombre}`} />
							</div>
							<div class="info">
								<h3>{miembro.nombre}</h3>
								<p>{miembro.cargo}</p>
							</div>
						</article>
					))}
				</div>

			</div>
		</section>
		<section class="bts-section">
			<div class="bts-header">
				<div class="header-content">
					<h2 class="bts-title">BEHIND THE SCENES</h2>
					<p class="bts-subtitle">Con las manos en la masa...</p>
				</div>
				<div class="bts-controls">
					<button class="bts-arrow prev" id="btsPrev" aria-label="Anterior">
						<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
					</button>
					<button class="bts-arrow next" id="btsNext" aria-label="Siguiente">
						<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
					</button>
				</div>
			</div>

			<div class="bts-track-container">
				<div class="bts-track" id="btsTrack">
					<div class="bts-slide-set">
						{fotosRodaje.map((foto) => (
							<div class="bts-item">
								<img src={foto.src} alt={foto.alt} loading="lazy" />
							</div>
						))}
					</div>
					<div class="bts-slide-set">
						{fotosRodaje.map((foto) => (
							<div class="bts-item">
								<img src={foto.src} alt={foto.alt} loading="lazy" />
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

	</main>

</Layout>

<script>
	const track = document.getElementById('btsTrack');
	const prevBtn = document.getElementById('btsPrev');
	const nextBtn = document.getElementById('btsNext');

	if (track && prevBtn && nextBtn) {
		let baseSpeed = 1; 
		let currentSpeed = baseSpeed; 
		let targetSpeed = baseSpeed; 
		let isHovered = false;
		let isFastForwarding = false; // Chivato para saber si estamos apretando el botón

		// 1. MOTOR DE GIRO CON INERCIA
		function loopCarrusel() {
			if (!track) return;

			// Suaviza la transición de velocidad (acelera y frena con estilo)
			currentSpeed += (targetSpeed - currentSpeed) * 0.1;
			track.scrollLeft += currentSpeed;
			
			const mitadWidth = track.scrollWidth / 2;
			
			if (track.scrollLeft >= mitadWidth) {
				track.scrollLeft -= mitadWidth; 
			} else if (track.scrollLeft <= 0) {
				track.scrollLeft += mitadWidth;
			}
			
			requestAnimationFrame(loopCarrusel);
		}

		requestAnimationFrame(loopCarrusel);

		// 2. PAUSA AL PASAR EL RATÓN (Solo si no estamos usando las flechas)
		function setHover(state: boolean) {
			isHovered = state;
			if (!isFastForwarding) { 
				targetSpeed = state ? 0 : baseSpeed;
			}
		}

		track.addEventListener('mouseenter', () => setHover(true));
		track.addEventListener('mouseleave', () => setHover(false));
		track.addEventListener('touchstart', () => setHover(true), { passive: true });
		track.addEventListener('touchend', () => setHover(false));
		track.addEventListener('touchcancel', () => setHover(false)); 

		// 3. LA MECÁNICA DE MANTENER PULSADO
		function startAcceleration(speed: number) {
			isFastForwarding = true;
			targetSpeed = speed; // Pisamos el acelerador a la velocidad que le pasemos (ej: 18 o -18)
		}

		function stopAcceleration() {
			isFastForwarding = false;
			// Al soltar el botón, comprobamos: si el ratón está sobre las fotos, se para (0). Si no, vuelve a velocidad de paseo.
			targetSpeed = isHovered ? 0 : baseSpeed;
		}

		// EVENTOS PARA EL BOTÓN "SIGUIENTE" (Avanzar)
		// Ordenadores
		nextBtn.addEventListener('mousedown', () => startAcceleration(8));
		nextBtn.addEventListener('mouseup', stopAcceleration);
		nextBtn.addEventListener('mouseleave', stopAcceleration); // Por si arrastran el ratón fuera del botón
		
		// Móviles
		nextBtn.addEventListener('touchstart', (e: Event) => { e.preventDefault(); startAcceleration(8); }, { passive: false });
		nextBtn.addEventListener('touchend', stopAcceleration);
		nextBtn.addEventListener('touchcancel', stopAcceleration);
		nextBtn.addEventListener('contextmenu', (e: Event) => e.preventDefault()); // Evita que salga el menú de opciones en iOS al mantener pulsado

		// EVENTOS PARA EL BOTÓN "ANTERIOR" (Rebobinar)
		// Ordenadores
		prevBtn.addEventListener('mousedown', () => startAcceleration(-18));
		prevBtn.addEventListener('mouseup', stopAcceleration);
		prevBtn.addEventListener('mouseleave', stopAcceleration);
		
		// Móviles
		prevBtn.addEventListener('touchstart', (e: Event) => { e.preventDefault(); startAcceleration(-18); }, { passive: false });
		prevBtn.addEventListener('touchend', stopAcceleration);
		prevBtn.addEventListener('touchcancel', stopAcceleration);
		prevBtn.addEventListener('contextmenu', (e: Event) => e.preventDefault());
	}
</script>

<style lang="scss">
	/* ==========================================
	   HERO (TEXTOS EN NEGRO - ESTILO INDEX)
	   ========================================== */
	.about-hero {
		background-color: var(--site-bg); /* Fondo negro */
		padding: 6rem 1.5rem 5rem;
		text-align: center;
	}

	.hero-container {
		max-width: 800px;
		margin: 0 auto;
	}

	.section-badge {
		font-family: var(--font-title);
		color: var(--site-accent);
		letter-spacing: 4px;
		font-size: 0.9rem;
		text-transform: uppercase;
		display: block;
		margin-bottom: 1.5rem;
	}

	.hero-title {
		font-family: var(--font-title); 
		font-size: 2rem;
		color: #ffffff;
		line-height: 1.2;
		margin-bottom: 2.5rem;
		
		@media (min-width: 768px) {
			font-size: 2.8rem;
		}
	}

	.hero-description {
		p {
			font-family: var(--font-title);
			font-size: 1.1rem;
			color: rgba(255, 255, 255, 0.7);
			line-height: 1.8;
			margin-bottom: 1.5rem;
			text-align: left;
			
			@media (min-width: 768px) {
				text-align: center;
			}
		}
	}

	/* ==========================================
	   SECCIÓN EQUIPO (EN BLANCO - ESTILO INDEX)
	   ========================================== */
	.team-section {
		background-color: var(--test-bg-page); /* Fondo blanco */
		padding: 5rem 1.5rem 8rem;
	}

	.team-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	.team-title {
		font-family: var(--font-title);
		font-size: 1.2rem;
		font-weight: 700;
		letter-spacing: 4px;
		color: #111; /* Letra oscura para el fondo blanco */
		text-align: center;
		margin-bottom: 4rem;
	}

	/* CSS GRID: MOBILE FIRST */
	.team-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem; 

		@media (min-width: 768px) {
			grid-template-columns: repeat(4, 1fr);
			gap: 2.5rem;
		}
	}

	/* TARJETAS DE PERFIL */
	.team-card {
		.img-wrapper {
			width: 100%;
			aspect-ratio: 4 / 5; 
			overflow: hidden;
			background-color: #f0f0f0; /* Fondo gris clarito por si tarda la foto */
			margin-bottom: 1rem; 
			border-radius: 2px;

			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				filter: grayscale(100%); 
				transition: filter 0.4s ease, transform 0.4s ease;
			}
		}

		/* EFECTO HOVER PROFESIONAL */
		&:hover {
			.img-wrapper img {
				filter: grayscale(0%);
				transform: scale(1.03);
			}
		}

		.info {
			text-align: left;
			
			h3 {
				font-family: var(--font-title);
				font-size: 0.9rem; 
				font-weight: 700;
				color: #222; /* Letra oscura sobre blanco */
				letter-spacing: 0.5px;
				margin-bottom: 0.2rem;

				@media (min-width: 768px) {
					font-size: 1.1rem;
				}
			}
			p {
				font-family: var(--font-title);
				font-size: 0.7rem; 
				font-weight: 600;
				color: var(--site-accent);
				text-transform: uppercase;
				letter-spacing: 1px;
				margin: 0;
			}
		}
	}

	/* ==========================================
	   SECCIÓN RODAJES (FONDO OSCURO)
	   ========================================== */
	.bts-section {
		background-color: #0a0a0a;
		padding: 5rem 0; /* Sin padding lateral para que el track llegue al borde */
		overflow: hidden;
	}

	.bts-header {
		max-width: 1200px;
		margin: 0 auto 3rem;
		padding: 0 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
	}

	.bts-title {
		font-family: var(--font-title);
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: 4px;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}

	.bts-subtitle {
		font-family: var(--font-title);
		font-size: 0.9rem;
		color: var(--site-accent);
		text-transform: uppercase;
		margin: 0;
	}

	.bts-controls {
		display: flex;
		gap: 1rem;
		
		.bts-arrow {
			width: 45px;
			height: 45px;
			border: 1px solid rgba(255,255,255,0.2);
			border-radius: 50%;
			color: white;
			display: flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			background: transparent;
			transition: all 0.3s ease;
			
			&:hover {
				background-color: var(--site-accent);
				border-color: var(--site-accent);
				transform: scale(1.05);
			}
			&:active {
				transform: scale(0.95);
			}
		}
	}

	.bts-track-container {
		padding: 0;
		overflow: hidden;
		width: 100%;
	}

	.bts-track {
		display: flex;
		width: 100%;
		overflow-x: auto; /* Fundamental para que iOS permita el movimiento */
		scroll-behavior: auto; 
		scrollbar-width: none; /* Oculta barra en Firefox */
		&::-webkit-scrollbar { display: none; } /* Oculta barra en Safari/iPhone */
	}

	.bts-slide-set {
		display: flex;
		gap: 1.5rem;
		padding-right: 1.5rem; /* Separación con el clon */
	}

	.bts-item {
		width: 280px; /* Medida fija para que el script calcule bien el infinito */
		flex-shrink: 0;
		aspect-ratio: 16 / 9;
		border-radius: 4px;
		overflow: hidden;
		background-color: #1a1a1a;

		@media (min-width: 768px) { width: 350px; }
		@media (min-width: 1024px) { width: 420px; }

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			transition: transform 0.5s ease;
			
			&:hover {
				transform: scale(1.05);
			}
		}
	}
</style>