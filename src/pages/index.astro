---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// 1. AQUÍ AÑADES TUS VÍDEOS Y PORTADAS DEL SLIDER (HERO)
const heroSlides = [
	{
		id: 1,
		titulo: "NUEVO TRÁILER",
		estado: "EN PRODUCCIÓN",
		logo: "/img/dubrovka_logo.webp", /* <-- Cambia por el logo de tu segundo proyeto */
		video: "/video/dubrovka.mp4",
		poster: "/img/cartel_dubrovka.webp" /* <-- Pon la portada del segundo tráiler */
	},
	{
		id: 1,
		titulo: "NUEVO TRÁILER",
		estado: "EN PRODUCCIÓN",
		logo: "/img/hollywood_logo.webp", /* <-- Cambia por el logo de tu segundo proyeto */
		video: "/video/hollywood.mp4",
		poster: "/img/cartel_hollywood.webp" /* <-- Pon la portada del segundo tráiler */
	},
	{
		id: 2,
		titulo: "NUEVO TRÁILER",
		estado: "EN PRODUCCIÓN",
		logo: "/img/raicesancestralesimg.webp", /* <-- Cambia por el logo de tu segundo proyeto */
		video: "/video/raices_ancestrales.mp4",
		poster: "/img/cartel_raices.webp" /* <-- Pon la portada del segundo tráiler */
	},
	
];

// 2. TUS PROYECTOS DE LA CUADRÍCULA INFERIOR
const proyectos = [
	{ titulo: "Dubrovka", estado: "Producción", imagen: "/img/dubrovka_portada.webp" },
	{ titulo: "Esto no es hollywood", estado: "Producción", imagen: "/img/hollywood_portada.webp" },
	{ titulo: "RAÍCES ANCESTRALES", estado: "Pre-producción", imagen: "/img/raices_ancestrales_portada.webp" },
];
---

<Layout title="Inicio" description="Cumbre Serena World Productions - Cine y Editorial">
	
	<section class="hero-slider" id="hero-slider">
		
		{heroSlides.map((slide, index) => (
			<div class={`hero-slide ${index === 0 ? 'active' : ''}`} data-index={index}>
				
				<video class="hero-bg-video" loop muted playsinline poster={slide.poster}>
					<source src={slide.video} type="video/mp4" />
				</video>
				<div class="video-overlay"></div>

				<div class="slide-content">
					<div class="hero-content-bottom">
						<div class="info-group">
							<img src={slide.logo} alt={`Logo de ${slide.titulo}`} class="movie-logo" />
							<p class="release-status">{slide.estado}</p>
						</div>
						
						<div class="action-group">
							<button class="btn btn-teal">VER MÁS</button>
							
							<button class="btn btn-teal btn-play-trailer">
								<svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
								VER TRÁILER
							</button>

							<div class="video-controls hidden">
								<button class="ctrl-icon btn-pause" aria-label="Pausar">
									<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
								</button>
								<button class="ctrl-icon btn-mute" aria-label="Silenciar">
									<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
								</button>
							</div>
						</div>
					</div>
				</div>

			</div>
		))}

		<button class="arrow prev" aria-label="Anterior">
			<svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
		</button>
		<button class="arrow next" aria-label="Siguiente">
			<svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
		</button>

		<div class="dots">
			{heroSlides.map((_, index) => (
				<span class={`dot ${index === 0 ? 'active' : ''}`} data-index={index}></span>
			))}
		</div>

	</section>

	<section class="projects-section" id="proyectos">
		<div class="projects-container">
			<div class="section-header">
				<h2 class="section-title">PROYECTOS</h2>
				<div class="carousel-controls">
					<button class="ctrl-btn prev" aria-label="Anterior"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
					<button class="ctrl-btn next" aria-label="Siguiente"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
				</div>
			</div>
			<div class="projects-grid">
				{proyectos.map((proyecto) => (
					<article class="project-card">
						<img src={proyecto.imagen} alt={`Póster de ${proyecto.titulo}`} class="poster-img" />
						<div class="project-info">
							<h3 class="project-title">{proyecto.titulo}</h3>
							<p class="project-status">{proyecto.estado}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="home-services">
			<div class="container">
				
				<div class="section-header align-center">
					<h2>Contamos historias que cautivan y emocionan</h2>
					<p>Una productora de cine profesional que une creatividad y experiencia para crear proyectos audiovisuales impactantes y únicos.</p>
				</div>

				<div class="services-grid">
					
					<article class="service-box">
						<div class="service-img">
							<img src="/img/rodaje12.webp" alt="Cámara de cine profesional" loading="lazy" />
						</div>
						<div class="service-content">
							<h3>Producción de<br>Cine Profesional</h3>
							<p>Creamos proyectos audiovisuales de alta calidad que transmiten emociones y mensajes claros.</p>
						</div>
					</article>

					<article class="service-box">
						<div class="service-img">
							<img src="/img/rodaje10.webp" alt="Cámara de cine profesional" loading="lazy" />
						</div>
						<div class="service-content">
							<h3>Narrativa visual creativa</h3>
							<p>Desarrollamos conceptos originales que convierten ideas en experiencias visuales memorables.</p>
						</div>
					</article>

					<article class="service-box">
						<div class="service-img">
							<img src="/img/rodaje11.webp" alt="Rodaje y claqueta" loading="lazy" />
						</div>
						<div class="service-content">
							<h3>Edición y Postproducción<br>Avanzada</h3>
							<p>Utilizamos técnicas innovadoras para perfeccionar cada detalle y lograr un acabado impecable.</p>
						</div>
					</article>

				</div>

				<div class="action-container">
					<a href="/servicios" class="btn">NUESTROS SERVICIOS</a>
				</div>

			</div>
		</section>
</Layout>

<script src="../scripts/slider.js"></script>

<style lang="scss">
	/* ==========================================
	   ESTILOS DEL HERO (SE MANTIENE IGUAL, object-fit: cover asegura que el poster cubra bien)
	   ========================================== */
	.hero-slider {
		position: relative; width: 100%; background-color: var(--site-bg); overflow: hidden;
		height: calc(100dvh - 60px); 
		@media (min-width: 1024px) { height: calc(100vh - 165px); }
	}

	.hero-slide {
		position: absolute; inset: 0; opacity: 0; visibility: hidden;
		transition: opacity 0.8s ease-in-out, visibility 0.8s; z-index: 1;
		&.active { opacity: 1; visibility: visible; z-index: 2; }
	}

	.hero-bg-video {
		position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; margin-top: 4rem;
		object-fit: contain; 
		object-position: top; /* <--- ESTO PEGA EL VÍDEO AL HEADER QUITANDO EL HUECO */
		
		/* En ordenador lo mantenemos centrado porque la pantalla es ancha */
		@media (min-width: 1024px) { 
			object-fit: cover; /* o contain, lo que prefieras para PC */
			object-position: center; 
			margin-top: 0;
		}
	}

	.video-overlay {
		position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 40%, transparent 100%); z-index: 2;
	}

	.slide-content {
		position: absolute; inset: 0; z-index: 5; display: flex; align-items: flex-end; justify-content: center;
		padding-bottom: 4.5rem; @media (min-width: 768px) { padding-bottom: 5.5rem; }
	}

	.hero-content-bottom {
		width: 100%; max-width: 1400px; padding: 0 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1.5rem;
		@media (min-width: 768px) { flex-direction: row; justify-content: space-between; align-items: flex-end; padding: 0 3rem; }
	}

	.info-group { 
		display: flex; 
		flex-direction: column; 
		align-items: center; 
		@media (min-width: 768px) { align-items: flex-start; } }
	.release-status { 
		font-family: var(--font-title); 
		font-size: 0.9rem; 
		color: rgba(255, 255, 255, 0.7); 
		margin-top: 0.3rem; 
		margin-left: 2rem;
		letter-spacing: 1px; 
	}
	.movie-logo { width: 100%; max-width: 280px; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.7)); margin-bottom: 0.5rem; @media (min-width: 768px) { max-width: 380px; } @media (min-width: 1200px) { max-width: 450px; } }
	

	.action-group { display: flex; gap: 0.8rem; justify-content: center; align-items: center; }
	
	.btn {
		display: inline-flex; 
		align-items: center; 
		justify-content: center; 
		gap: 0.5rem; 
		border-radius: 3px; 
		border: none; 
		font-family: var(--font-title); 
		font-weight: 700; 
		letter-spacing: 1px; cursor: pointer; 
		white-space: nowrap; 
		transition: background-color 0.3s, transform 0.2s;
		padding: 0.6rem 1.2rem !important; 
		font-size: 0.75rem !important; 
		background-color: var(--site-accent); 
		color: #ffffff;
		&:hover { filter: brightness(1.1); transform: translateY(-2px); }
		@media (min-width: 768px) { padding: 0.6rem 1.2rem !important; font-size: 0.75rem !important; }
	}

	.hidden { display: none !important; }

	.video-controls { display: flex; align-items: center; gap: 1.2rem; margin-left: 0.5rem; }
	.ctrl-icon { 
		background: none; border: none; color: #ffffff; cursor: pointer; opacity: 0.7; transition: all 0.2s; display: flex; align-items: center; justify-content: center;
		&:hover { opacity: 1; transform: scale(1.1); color: var(--site-accent); }
	}

	.arrow { 
		position: absolute; 
		top: 50%; 
		transform: translateY(-50%); 
		color: white; padding: 1rem; 
		opacity: 0.7; 
		z-index: 10; 
		cursor: pointer; 
		border: none; 
		background: none; 
		display: block; 
		@media (min-width: 1024px) 
		{ display: block; } &:hover { opacity: 1; } &.prev { left: 2%; } &.next { right: 2%; } }

	.dots { position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%); display: flex; gap: 0.5rem; z-index: 10; @media (min-width: 768px) { bottom: 2rem; } }
	.dot { width: 8px; height: 8px; border-radius: 50%; background-color: rgba(255,255,255,0.3); transition: background-color 0.3s; cursor: pointer; &.active { background-color: var(--site-accent); } }

	/* SECCIÓN PROYECTOS INTACTA */
	.projects-section { padding: 4rem 1rem; background-color: var(--test-bg-page); }
	.projects-container { max-width: 1400px; margin: 0 auto; }
	.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid rgba(0,0,0,0.1); padding-bottom: 1rem; }
	.section-title { font-family: var(--font-title); font-size: 1.5rem; font-weight: 700; color: #ffffff; margin: 2rem; }
	.carousel-controls { display: flex; gap: 0.5rem; }
	.ctrl-btn { background: none; border: 1px solid #ccc; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #555; transition: all 0.2s; &:hover { background-color: #f0f0f0; border-color: #999; } }
	.projects-grid { 
		display: flex; 
		flex-wrap: wrap; 
		justify-content: center; 
		gap: 1.5rem; }
	.project-card { 
		width: calc(50% - 0.75rem);
		max-width: 220px;
		background-color: rgb(22, 21, 21); 
		 @media (min-width: 768px) 
		 { width: calc(33.333% - 1rem); } 
		 @media (min-width: 1024px) 
		 { width: calc(16.666% - 1.25rem); } }
	.poster-img { width: 100%; 
		aspect-ratio: 4 / 6; 
		object-fit:fill; 
		display: block;  
		margin-bottom: 0.8rem; 
		box-shadow: 0 4px 10px rgb(47, 45, 45); }
	.project-info { 
		text-align: left; 
	}
	.project-title { 
		font-family: var(--font-title); 
		font-size: 0.9rem; 
		font-weight: 700; 
		color: #887f7f; 
		text-transform: uppercase; 
		margin: 0 0 0.2rem 0; 
		line-height: 1.2;
	padding-left: 0.5rem; }

	.project-status { 
		font-family: var(--font-title); 
		font-size: 0.8rem; 
		color: #887f7f; 
		padding: 0 0 0.5rem 0.5rem;
		margin: 0;
		}

	/* ==========================================
	   SECCIÓN SERVICIOS (INDEX)
	   ========================================== */
	.home-services {
		background-color: var(--site-bg);
		padding: 6rem 1.5rem;
	}

	.home-services .container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Cabecera centrada usando tu estilo */
	.home-services .section-header {
		text-align: center;
		max-width: 800px;
		margin: 0 auto 4rem auto;
		display: flex;
		flex-direction: column;
		align-items: center;

		h2 {
			font-family: var(--font-title);
			font-size: clamp(2rem, 4vw, 3.5rem);
			color: #ffffff;
			margin-bottom: 1.5rem;
			line-height: 1.1;
		}

		p {
			font-family: var(--font-body);
			font-size: 1.2rem;
			color: rgba(255, 255, 255, 0.7);
			line-height: 1.6;
		}
	}

	/* Cuadrícula de Cajitas */
	.services-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		margin-bottom: 3rem;

		@media (min-width: 768px) {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.service-box {
		background-color: #000000; /* Fondo negro puro como en la captura */
		border-radius: 4px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		border: 1px solid rgba(255, 255, 255, 0.05);

		/* Magia para la tarjeta que no tiene foto */
		&.text-only {
			justify-content: center;
		}
	}

	.service-img {
		width: 100%;
		aspect-ratio: 4 / 3;
		overflow: hidden;

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			transition: transform 0.5s ease;
		}
	}

	.service-box:hover .service-img img {
		transform: scale(1.05); /* Efecto zoom premium al pasar el ratón */
	}

	.service-content {
		padding: 3rem 2rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		flex: 1;

		h3 {
			font-family: var(--font-title);
			font-size: 1.4rem;
			color: #ffffff;
			margin-bottom: 1.2rem;
			line-height: 1.3;
		}

		p {
			font-family: var(--font-body);
			font-size: 0.95rem;
			color: rgba(255, 255, 255, 0.6);
			line-height: 1.6;
		}
	}

	.action-container {
		text-align: center;
		margin-top: 1rem;
	}
</style>